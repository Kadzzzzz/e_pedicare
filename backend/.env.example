# Configuration e-PediCare Backend

# ======================
# LiveKit Configuration
# ======================
# Récupérez vos clés sur https://livekit.io/cloud
# 1. Créez un compte gratuit
# 2. Créez un projet
# 3. Copiez l'URL et les clés API depuis Settings > Keys

LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxx

# ======================
# Flask Configuration
# ======================

# JWT Secret Key - IMPORTANT: Changez cette valeur en production !
# Générez une clé aléatoire sécurisée avec: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-key-change-in-production-12345

# Database URI
# Par défaut SQLite local (pour développement)
DATABASE_URI=sqlite:///database/epedicare.db
# Pour PostgreSQL (production): DATABASE_URI=postgresql://user:password@localhost/epedicare
# Pour MySQL: DATABASE_URI=mysql://user:password@localhost/epedicare

# ======================
# Environnement
# ======================
FLASK_ENV=development
# En production, changez en: FLASK_ENV=production
